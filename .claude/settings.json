    ],
    "deny": [],
    "ask": [],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); cwd=$(echo \"$input\" | jq -r '.workspace.current_dir'); cwd_display=\"${cwd/#$HOME/~}\"; if git -C \"$cwd\" rev-parse --git-dir > /dev/null 2>&1; then branch=$(git -C \"$cwd\" --no-optional-locks rev-parse --abbrev-ref HEAD 2>/dev/null); git_info=\" ($branch)\"; else git_info=\"\"; fi; model=$(echo \"$input\" | jq -r '.model.display_name'); used_pct=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); if [ -n \"$used_pct\" ]; then used_int=$(printf \"%.0f\" \"$used_pct\"); context_info=\" [ctx: ${used_int}%]\"; else context_info=\"\"; fi; echo \"${cwd_display}${git_info} | ${model}${context_info}\""
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
}
